# Application
APP_NAME=my-api-lambda
APP_VERSION=1.0.0
NODE_ENV=development
PORT=3000

# AWS (used by GitHub Actions / AWS CLI — not required at runtime inside Lambda)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY

# Lambda deployment settings
LAMBDA_FUNCTION_NAME=my-api-lambda
LAMBDA_ROLE_ARN=arn:aws:iam::123456789012:role/lambda-execution-role